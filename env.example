PORT=3000
# Public URL of this app (must be reachable by Shopify). Example: https://your-domain.com
APP_URL=https://example.com

# Shopify app credentials (create an app in Shopify Partners or a custom app, depending on your use-case)
SHOPIFY_API_KEY=your_api_key
SHOPIFY_API_SECRET=your_api_secret

# Comma-separated scopes needed to read order data
SHOPIFY_SCOPES=read_orders,read_customers,read_fulfillments

# Admin API version (keep consistent)
SHOPIFY_API_VERSION=2025-10

# Which webhook topics to register (comma-separated)
SHOPIFY_WEBHOOK_TOPICS=orders/create,orders/cancelled,orders/paid,orders/fulfilled,refunds/create,orders/updated

# Where to store installed shops/tokens
SQLITE_PATH=./data/app.db

# Your WAB2C endpoint to receive events (the webhook you generate from your dashboard)
WAB2C_WEBHOOK_URL=https://your-wab2c-domain.com/webhook/xxxx

# Optional: add an auth header when forwarding to WAB2C 
WAB2C_AUTH_HEADER_NAME=Authorization
WAB2C_AUTH_HEADER_VALUE=Bearer your_token

# --- Optional: send WhatsApp directly via WhatsMark SaaS API ---
# If set, the app will use WhatsMark SaaS API instead of (or in addition to) forwarding raw webhooks.
# Domain WITHOUT https:// (example: app.wab2c.com or your-whatsmark-domain.com)
WHATSMARK_DOMAIN=yourdomain.com
# Tenant/subdomain (example from docs: tenantx). This is required because endpoints are /api/v1/{tenant}/...
WHATSMARK_TENANT=tenantx
# API token from WhatsMark SaaS -> Tenant -> API Management
WHATSMARK_API_TOKEN=your_api_token

# Which WhatsMark templates to send for each Shopify topic (optional).
# If template name is empty, the app will fall back to simple text message for that event.
WHATSMARK_TEMPLATE_ORDERS_CREATE=order_created
WHATSMARK_TEMPLATE_ORDERS_CANCELLED=order_cancelled
WHATSMARK_TEMPLATE_ORDERS_PAID=order_paid
WHATSMARK_TEMPLATE_ORDERS_FULFILLED=order_fulfilled
WHATSMARK_TEMPLATE_REFUNDS_CREATE=refund_created
WHATSMARK_TEMPLATE_ORDERS_UPDATED=



